{
  "name": "isekai-gatekeeper",
  "version": "0.1.0",
  "description": "AI 爬虫防火墙代理 — PoW + 规则引擎 + 缓存",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "stress": "bun scripts/stress-test.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "build": "tsc",
    "build:bundle": "bun build src/main.ts --outdir dist --target bun --format cjs --minify",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@koa/bodyparser": "^5.1.1",
    "@koa/router": "^13.1.0",
    "cache-manager": "^6.4.2",
    "chokidar": "^5.0.0",
    "geoip-lite": "^2.0.1",
    "handlebars": "^4.7.8",
    "koa": "^3.0.0",
    "koa-mount": "^4.2.0",
    "koa-static": "^5.0.0",
    "maxmind": "^5.0.6",
    "path-to-regexp": "^8.4.2",
    "smol-toml": "^1.3.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa-static": "^4.0.4",
    "@types/koa__router": "^12.0.4",
    "@types/koa-mount": "^4.0.5",
    "@types/node": "^22.15.3",
    "bun-types": "^1.3.13",
    "typescript": "^5.8.3"
  }
}
