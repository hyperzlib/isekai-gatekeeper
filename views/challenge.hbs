<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=Edge">
  <meta name="robots" content="noindex,nofollow">
  <title>正在验证您的浏览器…</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: system-ui, sans-serif;
      background: #f5f5f5;
      color: #333;
    }
    .card {
      background: #fff;
      border-radius: 12px;
      padding: 2.5rem 3rem;
      box-shadow: 0 4px 24px rgba(0,0,0,.08);
      text-align: center;
      max-width: 400px;
      width: 100%;
    }
    h1 { font-size: 1.25rem; margin-bottom: .75rem; }
    p  { font-size: .9rem; color: #666; margin-bottom: 1.5rem; }
    .spinner {
      width: 40px; height: 40px;
      border: 3px solid #e0e0e0;
      border-top-color: #555;
      border-radius: 50%;
      animation: spin .8s linear infinite;
      margin: 0 auto 1.5rem;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    #status { font-size: .85rem; color: #888; min-height: 1.2em; }
    #captcha-container { display: none; margin-top: 1.5rem; }
  </style>
</head>
<body>
  <div class="card">
    <div class="spinner" id="spinner"></div>
    <h1>正在验证您的浏览器</h1>
    <p>请稍候，这通常只需几秒钟。</p>
    <div id="status">正在准备验证…</div>

    {{#if captchaProvider}}
    <div id="captcha-container">
      <!-- 验证码 widget 由 provider 脚本动态渲染 -->
    </div>
    {{/if}}
  </div>

  <canvas id="c" hidden></canvas>

  <script type="application/json" id="challenge-data">
    {
      "challengeApi": "{{challengeApiPath}}",
      "verifyApi": "{{verifyApiPath}}",
      "captchaProvider": "{{captchaProvider}}",
      "captchaSiteKey": "{{captchaSiteKey}}",
      "captchaGtId": "{{captchaGtId}}",
      "captchaPublicKey": "{{captchaPublicKey}}",
      "captchaAppId": "{{captchaAppId}}"
    }
  </script>
  <script src="/.isekai-gatekeeper/public/js/pow.js"></script>
</body>
</html>
